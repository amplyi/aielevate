# Copy to deploy.env and fill in values from:
# WordPress.com → Sites → aielevate.xyz → Settings → SFTP/SSH
#
# Requires WordPress.com Business or Commerce plan.

WP_SITE_URL=https://aielevate.xyz
WP_SFTP_HOST=your-site.sftp.wp.com
WP_SFTP_PORT=22
WP_SFTP_USER=your-sftp-username
WP_SFTP_PASSWORD=your-sftp-password

# Remote plugin path (do not change unless you renamed the plugin folder)
WP_REMOTE_PLUGIN_PATH=/srv/htdocs/wp-content/plugins/ai-elevate-cockpit-standalone

# Local plugin source folder (relative to repo root)
WP_PLUGIN_SOURCE=ai-elevate-cockpit-plugin-v4-standalone
